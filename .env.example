# Polymarket API
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_WALLET_ADDRESS=your_wallet_address_here

# Exchange APIs (read-only for price monitoring)
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET_KEY=your_binance_secret
BYBIT_API_KEY=your_bybit_key
BYBIT_SECRET_KEY=your_bybit_secret
COINBASE_API_KEY=your_coinbase_key
COINBASE_SECRET_KEY=your_coinbase_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Trading Mode
PAPER_TRADING=true

# Trading Parameters
MAX_RISK_PER_TRADE=0.5
DAILY_LOSS_LIMIT=2.0
MIN_EDGE_PERCENTAGE=10.0
MAX_OPEN_POSITIONS=5

# Strategies (enable/disable)
ENABLE_LATENCY_ARBITRAGE=true
ENABLE_MARKET_MAKING=false
ENABLE_COPY_TRADING=false

# Time frames to trade
TRADE_5MIN=true
TRADE_15MIN=true
TRADE_1HOUR=true

# Assets to monitor
ASSETS=BTC,ETH,SOL,XRP
